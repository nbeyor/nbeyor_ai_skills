# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Anthropic API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Your Telegram user ID (for security + reminders). Find it by messaging @userinfobot on Telegram.
# Comma-separated if multiple users. Leave empty to allow anyone (not recommended).
ALLOWED_USER_IDS=

# Directory for all SQLite database files (default: ./data)
# DATA_DIR=./data

# How often to check for due reminders, in minutes (default: 5)
# REMINDER_CHECK_MINUTES=5

# Claude model (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514
